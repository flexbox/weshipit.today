{
  "name": "preview-banner",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/preview-banner",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/next:build",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/apps/preview-banner"
      },
      "configurations": {
        "development": {
          "outputPath": "apps/preview-banner"
        },
        "production": {}
      }
    },
    "serve": {
      "executor": "@nx/next:server",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "preview-banner:build",
        "dev": true,
        "port": 4300
      },
      "configurations": {
        "development": {
          "buildTarget": "preview-banner:build:development",
          "dev": true
        },
        "production": {
          "buildTarget": "preview-banner:build:production",
          "dev": false
        }
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/apps/preview-banner"],
      "options": {
        "jestConfig": "apps/preview-banner/jest.config.ts"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    }
  }
}
